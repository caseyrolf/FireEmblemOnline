generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model GameRoom {
  roomCode    String   @id
  hostId      String
  stateJson   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model User {
  id          String             @id
  email       String             @unique
  passwordHash String
  salt        String
  displayName String
  wins        Int                @default(0)
  losses      Int                @default(0)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  sessions    AuthSession[]
  characters  ProfileCharacter[]
  campaigns   ProfileCampaign[]
}

model AuthSession {
  token     String   @id
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ProfileCharacter {
  id         String   @id
  userId     String
  name       String
  className  String
  portraitUrl String?
  skillId    String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ProfileCampaign {
  id                 String   @id
  userId             String
  name               String
  allowedPlayerUnits Int
  campaignJson       String
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
